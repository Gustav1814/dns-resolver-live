# DNS-over-HTTPS endpoint overrides (optional)
# Use {name} and {type} as placeholders.
#
# Cloudflare — {type} is the RR name string (A, NS, MX, etc.)
# VITE_DOH_CLOUDFLARE_URL=https://cloudflare-dns.com/dns-query?name={name}&type={type}
#
# Google — {type} is the numeric RR type (1=A, 2=NS, 15=MX, etc.)
# VITE_DOH_GOOGLE_URL=https://dns.google/resolve?name={name}&type={type}
